{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/business-concept-package.schema.json",
  "title": "Business Concept Builder Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "businessSummary",
    "customerProblemSegments",
    "offers",
    "productLadder",
    "pricingLogic",
    "freeLeadMagnet",
    "addOns",
    "recurringContracts",
    "sitemap",
    "pageOutlines",
    "intakeQuestions",
    "productRecords",
    "sopList",
    "businessOSConfiguration",
    "businessPackDraft",
    "launchPlan30Days",
    "socialThemes",
    "socialDrafts",
    "expenseCategories",
    "risks",
    "missingInformation",
    "decisions",
    "tasks",
    "records",
    "ownerReviewChecklist",
    "commercializationBlockers"
  ],
  "properties": {
    "metadata": {
      "type":"object",
      "required":["schema","version","generatedAt","status","inputDigest","automaticExternalActions","selfApproved","externalActionsOccurred"],
      "properties": {
        "schema":{"const":"BUSINESS-CONCEPT-PACKAGE-2.0"},
        "version":{"type":"string"},
        "generatedAt":{"type":"string"},
        "status":{"const":"OWNER_REVIEW_REQUIRED"},
        "inputDigest":{"type":"string","minLength":16},
        "automaticExternalActions":{"const":false},
        "selfApproved":{"const":false},
        "externalActionsOccurred":{"const":false},
        "redactionsApplied":{"type":"integer","minimum":0}
      }
    },
    "businessSummary":{"type":"object"},
    "customerProblemSegments":{"type":"array","minItems":1},
    "offers":{"type":"array","minItems":5},
    "productLadder":{"type":"array","minItems":5},
    "pricingLogic":{"type":"object"},
    "freeLeadMagnet":{"type":"object"},
    "addOns":{"type":"array","minItems":6},
    "recurringContracts":{"type":"array","minItems":2},
    "sitemap":{"type":"array","minItems":8,"items":{"type":"string"}},
    "pageOutlines":{"type":"object"},
    "intakeQuestions":{"type":"array","minItems":12},
    "productRecords":{"type":"array","minItems":5},
    "sopList":{"type":"array","minItems":20},
    "businessOSConfiguration":{"type":"object"},
    "businessPackDraft":{"type":"object"},
    "launchPlan30Days":{"type":"array","minItems":5},
    "socialThemes":{"type":"array","minItems":6},
    "socialDrafts":{"type":"array","minItems":6},
    "expenseCategories":{"type":"array","minItems":16},
    "risks":{"type":"array","minItems":7},
    "missingInformation":{"type":"array","minItems":8},
    "decisions":{"type":"array","minItems":10},
    "tasks":{"type":"array","minItems":25},
    "records":{"type":"object"},
    "ownerReviewChecklist":{"type":"array","minItems":6},
    "commercializationBlockers":{"type":"array","minItems":5}
  }
}
