{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/business-concept-input.schema.json",
  "title": "Business Concept Builder Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "businessName",
    "idea",
    "ownerSkills",
    "customers",
    "serviceArea",
    "assetsEquipment",
    "timeAvailable",
    "launchBudget",
    "contactPreference",
    "revenueGoals",
    "businessModels",
    "restrictions",
    "risks",
    "currentSystems",
    "expansionIdeas",
    "primaryProblem",
    "primaryOutcome"
  ],
  "properties": {
    "businessName": {"type":"string","minLength":2,"maxLength":120},
    "idea": {"type":"string","minLength":12,"maxLength":8000},
    "ownerSkills": {"type":"array","minItems":1,"items":{"type":"string","minLength":1,"maxLength":500}},
    "customers": {"type":"array","minItems":1,"items":{"type":"string","minLength":1,"maxLength":500}},
    "serviceArea": {"type":"string","minLength":1,"maxLength":500},
    "assetsEquipment": {"type":"array","minItems":1,"items":{"type":"string","minLength":1,"maxLength":500}},
    "timeAvailable": {"type":"string","minLength":1,"maxLength":200},
    "hoursPerWeek": {"type":"number","exclusiveMinimum":0,"maximum":168},
    "launchBudget": {"type":"string","minLength":1,"maxLength":200},
    "monthlyRevenueGoal": {"type":"number","minimum":0},
    "contactPreference": {"type":"string","minLength":1,"maxLength":500},
    "revenueGoals": {"type":"string","minLength":1,"maxLength":500},
    "businessModels": {
      "type":"array",
      "minItems":1,
      "uniqueItems":true,
      "items":{"enum":["physical","digital","local","online"]}
    },
    "restrictions": {"type":"string","minLength":1,"maxLength":8000},
    "risks": {"type":"string","minLength":1,"maxLength":8000},
    "currentSystems": {"type":"string","minLength":1,"maxLength":8000},
    "expansionIdeas": {"type":"string","minLength":1,"maxLength":8000},
    "primaryProblem": {"type":"string","minLength":1,"maxLength":1000},
    "primaryOutcome": {"type":"string","minLength":1,"maxLength":1000},
    "confirmedFacts": {"type":"array","items":{"type":"string","maxLength":500}}
  }
}
