{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/signed-business-os-license.schema.json",
  "title": "Signed Business OS Commercial License",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "algorithm", "keyId", "payload", "payloadSha256", "signature", "signedAt", "externalActionsEnabled"],
  "properties": {
    "schemaVersion": {"const": 1},
    "algorithm": {"const": "Ed25519"},
    "keyId": {"type": "string", "minLength": 1, "maxLength": 128},
    "payloadSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "signature": {"type": "string", "minLength": 32},
    "signedAt": {"type": "string"},
    "externalActionsEnabled": {"const": false},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "licenseId", "customerId", "issuedAt", "validFrom", "validUntil", "status", "tier", "tenantLimit", "seatLimit", "tenantKeys", "releaseChannels", "modules", "features", "addOns", "supportPlan", "commercialTermsVersion", "metadata"],
      "properties": {
        "schemaVersion": {"const": 1},
        "licenseId": {"type": "string", "minLength": 1},
        "customerId": {"type": "string", "minLength": 1},
        "issuedAt": {"type": "string"},
        "validFrom": {"type": "string"},
        "validUntil": {"type": ["string", "null"]},
        "status": {"enum": ["ACTIVE", "SUSPENDED", "EXPIRED", "REVOKED", "DRAFT"]},
        "tier": {"enum": ["Core", "Operations", "Growth", "Control"]},
        "tenantLimit": {"type": "integer", "minimum": 1},
        "seatLimit": {"type": "integer", "minimum": 1},
        "tenantKeys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "releaseChannels": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["stable", "candidate", "development"]}},
        "modules": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "features": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "addOns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "supportPlan": {"type": "string", "minLength": 1},
        "commercialTermsVersion": {"type": "string", "minLength": 1},
        "metadata": {"type": "object"}
      }
    }
  }
}
