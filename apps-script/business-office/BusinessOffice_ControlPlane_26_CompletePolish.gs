/** Complete-polish operating layer: friendly references, attention counts, job-cost summary, and enriched task names. */
function boCtlRows_(sheet){try{return boReadTable_(sheet,{includeVoided:false});}catch(error){return[];}}
function boCtlText_(row,keys){for(var i=0;i<keys.length;i++){var value=boNormalizeText_(row&&row[keys[i]]);if(value)return value;}return'';}
function boCtlNumber_(value){return Number(String(value==null?'':value).replace(/[$,]/g,''))||0;}
function boCtlReference_(rows,idKeys,nameKeys,filter){return rows.filter(function(row){return !filter||filter(row);}).map(function(row){return{id:boCtlText_(row,idKeys),name:boCtlText_(row,nameKeys)||boCtlText_(row,idKeys),customerId:boCtlText_(row,['Customer ID']),jobId:boCtlText_(row,['Job ID'])};}).filter(function(row){return row.id;}).slice(0,500);}
function boControlPolishReferences_(caps){if(!caps.assignWork)return{users:[],roles:[],foremen:[],customers:[],properties:[],jobs:[],workOrders:[]};var users=boCtlRows_(H38_BO_SHEETS.USERS),roles=boCtlRows_(H38_BO_SHEETS.ROLES);return{users:boCtlReference_(users,['User ID'],['Display Name','Name','Email'],function(row){return !/Inactive|Voided/i.test(boCtlText_(row,['Status']));}),roles:roles.map(function(row){return{id:boCtlText_(row,['Role ID']),name:boCtlText_(row,['Role Name'])};}).filter(function(row){return row.name&&!/Owner|Viewer/.test(row.name);}),foremen:boCtlReference_(users,['User ID'],['Display Name','Name','Email'],function(row){return /Foreman/i.test(boCtlText_(row,['Role Name','Role','Role ID']));}),customers:boCtlReference_(boCtlRows_(H38_BO_SHEETS.CUSTOMERS),['Customer ID'],['Customer Name','Name','Company Name']),properties:boCtlReference_(boCtlRows_(H38_BO_SHEETS.ADDRESSES),['Address ID'],['Address Name','Label','Street 1','Address']),jobs:boCtlReference_(boCtlRows_(H38_BO_SHEETS.JOBS),['Job ID'],['Job Name','Name','Title','Job ID']),workOrders:boCtlReference_(boCtlRows_(H38_BO_SHEETS.WORK_ORDERS),['Work Order ID'],['Work Order Name','Title','Description','Work Order ID'])};}
function boControlPolishAttention_(role){if(role!=='Owner'&&role!=='Administrator')return{};var tasks=typeof h38TmListTasks_==='function'?h38TmListTasks_({limit:500}):[],today=Utilities.formatDate(new Date(),boTimeZone_(),'yyyy-MM-dd');return{unassigned:tasks.filter(function(row){return !boCtlText_(row,['Assigned User ID'])&&!boCtlText_(row,['Assigned Role'])&&!/Completed|Cancelled|Voided/.test(boCtlText_(row,['Status']));}).length,approvals:boCtlRows_(H38_BO_SHEETS.APPROVALS).filter(function(row){return !/Approved|Rejected|Cancelled|Voided/.test(boCtlText_(row,['Status','Approval Status']));}).length,proof:boControlPendingProof_().length,receipts:boCtlRows_(H38_BO_SHEETS.RECEIPTS).filter(function(row){return /Required|Pending|Review/i.test(boCtlText_(row,['Approval Status','Status']));}).length,requests:boCtlRows_(H38_BO_SHEETS.REQUESTS).filter(function(row){return /New|Open|Needs|Unassigned/i.test(boCtlText_(row,['Status']));}).length,overdueInvoices:boCtlRows_(H38_BO_SHEETS.INVOICES).filter(function(row){return boCtlText_(row,['Due Date'])&&boCtlText_(row,['Due Date'])<today&&!/Paid|Void|Cancelled/.test(boCtlText_(row,['Status','Payment Status']));}).length,equipmentIssues:boCtlRows_(H38_BO_SHEETS.ASSETS).filter(function(row){return /Unsafe|Out of Service|Service Due|Maintenance/i.test(boCtlText_(row,['Status','Availability Status','Condition']));}).length,errors:boCtlRows_(H38_BO_SHEETS.ERROR_LOG).filter(function(row){return !/Resolved|Closed|Ignored/.test(boCtlText_(row,['Status']));}).length};}
function boControlPolishJobCosts_(role){if(role!=='Owner'&&role!=='Administrator'&&role!=='Bookkeeper')return[];var labor=boCtlRows_(H38_BO_SHEETS.JOB_LABOR),materials=boCtlRows_(H38_BO_SHEETS.JOB_MATERIALS),equipment=boCtlRows_(H38_BO_SHEETS.JOB_EQUIPMENT),invoices=boCtlRows_(H38_BO_SHEETS.INVOICES),receipts=boCtlRows_(H38_BO_SHEETS.RECEIPTS);return boCtlRows_(H38_BO_SHEETS.JOBS).filter(function(job){return !/Completed|Cancelled|Voided/.test(boCtlText_(job,['Status']));}).slice(0,50).map(function(job){var id=boCtlText_(job,['Job ID']),sum=function(rows,fields){return rows.filter(function(row){return boCtlText_(row,['Job ID'])===id;}).reduce(function(total,row){for(var i=0;i<fields.length;i++){var number=boCtlNumber_(row[fields[i]]);if(number)return total+number;}return total;},0);},revenue=sum(invoices,['Total','Invoice Total','Amount']),laborCost=sum(labor,['Actual Cost','Labor Cost','Cost','Amount']),materialCost=sum(materials,['Actual Cost','Material Cost','Cost','Amount']),equipmentCost=sum(equipment,['Actual Cost','Equipment Cost','Cost','Amount']);return{id:id,name:boCtlText_(job,['Job Name','Name','Title'])||id,revenue:revenue,labor:laborCost,materials:materialCost,equipment:equipmentCost,margin:revenue-laborCost-materialCost-equipmentCost,pendingReceipts:receipts.filter(function(row){return boCtlText_(row,['Job ID'])===id&&/Required|Pending|Review/i.test(boCtlText_(row,['Approval Status','Status']));}).length};});}
function boControlApplyCompletePolish_(data,role){data.references=boControlPolishReferences_(data.capabilities||{});var customerNames={},jobNames={},workOrderNames={};data.references.customers.forEach(function(row){customerNames[row.id]=row.name;});data.references.jobs.forEach(function(row){jobNames[row.id]=row.name;});data.references.workOrders.forEach(function(row){workOrderNames[row.id]=row.name;});data.tasks=(data.tasks||[]).map(function(task){var copy=Object.assign({},task);copy['Customer Name']=customerNames[copy['Customer ID']]||'';copy['Job Name']=jobNames[copy['Job ID']]||workOrderNames[copy['Work Order ID']]||'';return copy;});data.attention=boControlPolishAttention_(role);data.jobCosts=boControlPolishJobCosts_(role);if(role==='Owner'||role==='Administrator'){data.actions.push(boControlAction_('dispatch','Schedule & Dispatch','🗓','control:dispatch',true));data.actions.push(boControlAction_('job-cost','Job Cost','◫','control:job-cost',false));data.actions.push(boControlAction_('communications','Communications','✉','bo:messages',false));}return data;}
var boControlLiveBootstrapBeforeCompletePolish_=boControlLiveBootstrap_;
boControlLiveBootstrap_=function(){var data=boControlLiveBootstrapBeforeCompletePolish_(),role=data.user&&data.user.role||'';return boControlApplyCompletePolish_(data,role);};