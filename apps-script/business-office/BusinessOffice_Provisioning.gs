  return{status:'PASS',installationId:installationId,packId:pack.packId,businessId:pack.business.id,spreadsheetId:spreadsheetId,rootFolderId:root.getId(),documentFolderId:documents.getId(),pdfFolderId:pdfs.getId(),exportFolderId:exports.getId(),backupFolderId:backups.getId(),validation:validation};
}
